<div id="res-form-store" hidden>
<form class="res-form" data-service="table" novalidate><input type="text" name="_honey" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true"><div class="fk" data-i18n="res.fk">Reserveringsaanvraag</div><h3 data-i18n="svc.table.t">·</h3><div class="frow"><div class="field"><label for="f-table-name" data-i18n="res.l.name">Naam</label><input id="f-table-name" name="name" type="text" autocomplete="name" required></div><div class="field"><label for="f-table-email" data-i18n="res.l.email">E-mailadres</label><input id="f-table-email" name="email" type="email" autocomplete="email" required></div></div><div class="field"><label for="f-table-guests" data-i18n="res.l.guests">Aantal personen</label><input id="f-table-guests" name="guests" type="number" min="1" value="2"></div><div class="frow"><div class="field"><label for="f-table-date" data-i18n="res.l.date">Datum</label><input id="f-table-date" name="date" type="date" ></div><div class="field"><label for="f-table-time" data-i18n="res.l.time">Tijd</label><input id="f-table-time" name="time" type="time" value="18:00"></div></div><div class="field"><label for="f-table-note" data-i18n="res.l.note">Opmerking (optioneel)</label><textarea id="f-table-note" name="note"></textarea></div><button type="submit" class="btn btn-gold" data-i18n="res.submit">Verstuur aanvraag</button><p class="form-note" data-i18n="res.note2">Uw aanvraag wordt direct naar ons verstuurd — geen e-mailprogramma nodig. Wij bevestigen persoonlijk.</p><div class="form-status" role="status" aria-live="polite"></div></form>
<form class="res-form" data-service="bike" novalidate><input type="text" name="_honey" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true"><div class="fk" data-i18n="res.fk">Reserveringsaanvraag</div><h3 data-i18n="svc.bike.t">·</h3><div class="frow"><div class="field"><label for="f-bike-name" data-i18n="res.l.name">Naam</label><input id="f-bike-name" name="name" type="text" autocomplete="name" required></div><div class="field"><label for="f-bike-email" data-i18n="res.l.email">E-mailadres</label><input id="f-bike-email" name="email" type="email" autocomplete="email" required></div></div><div class="frow"><div class="field"><label for="f-bike-std_bikes" data-i18n="res.b.std">Aantal gewone fietsen</label><input id="f-bike-std_bikes" name="std_bikes" type="number" min="0" value="0"></div><div class="field"><label for="f-bike-e_bikes" data-i18n="res.b.e">Aantal e-bikes</label><input id="f-bike-e_bikes" name="e_bikes" type="number" min="0" value="0"></div></div><div class="frow"><div class="field"><label for="f-bike-pickup_date" data-i18n="res.b.pud">Ophaaldatum</label><input id="f-bike-pickup_date" name="pickup_date" type="date" ></div><div class="field"><label for="f-bike-pickup_time" data-i18n="res.b.put">Ophaaltijd</label><input id="f-bike-pickup_time" name="pickup_time" type="time" value="10:00"></div></div><div class="frow"><div class="field"><label for="f-bike-dropoff_date" data-i18n="res.b.dod">Inleverdatum</label><input id="f-bike-dropoff_date" name="dropoff_date" type="date" ></div><div class="field"><label for="f-bike-dropoff_time" data-i18n="res.b.dot">Inlevertijd</label><input id="f-bike-dropoff_time" name="dropoff_time" type="time" value="17:00"></div></div><div class="field"><label for="f-bike-note" data-i18n="res.l.note">Opmerking (optioneel)</label><textarea id="f-bike-note" name="note"></textarea></div><button type="submit" class="btn btn-gold" data-i18n="res.submit">Verstuur aanvraag</button><p class="form-note" data-i18n="res.note2">Uw aanvraag wordt direct naar ons verstuurd — geen e-mailprogramma nodig. Wij bevestigen persoonlijk.</p><div class="form-status" role="status" aria-live="polite"></div></form>
<form class="res-form" data-service="jacuzzi" novalidate><input type="text" name="_honey" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true"><div class="fk" data-i18n="res.fk">Reserveringsaanvraag</div><h3 data-i18n="svc.jac.t">·</h3><div class="frow"><div class="field"><label for="f-jacuzzi-name" data-i18n="res.l.name">Naam</label><input id="f-jacuzzi-name" name="name" type="text" autocomplete="name" required></div><div class="field"><label for="f-jacuzzi-email" data-i18n="res.l.email">E-mailadres</label><input id="f-jacuzzi-email" name="email" type="email" autocomplete="email" required></div></div><div class="frow"><div class="field"><label for="f-jacuzzi-start_date" data-i18n="res.l.startdate">Startdatum</label><input id="f-jacuzzi-start_date" name="start_date" type="date" ></div><div class="field"><label for="f-jacuzzi-start_time" data-i18n="res.l.starttime">Starttijd</label><input id="f-jacuzzi-start_time" name="start_time" type="time" value="19:00"></div></div><div class="frow"><div class="field"><label for="f-jacuzzi-end_date" data-i18n="res.l.enddate">Einddatum</label><input id="f-jacuzzi-end_date" name="end_date" type="date" ></div><div class="field"><label for="f-jacuzzi-end_time" data-i18n="res.l.endtime">Eindtijd</label><input id="f-jacuzzi-end_time" name="end_time" type="time" value="21:00"></div></div><div class="field"><label for="f-jacuzzi-room" data-i18n="res.j.room">Kamernummer</label><input id="f-jacuzzi-room" name="room" type="text" ></div><div class="field"><label for="f-jacuzzi-note" data-i18n="res.l.note">Opmerking (optioneel)</label><textarea id="f-jacuzzi-note" name="note"></textarea></div><button type="submit" class="btn btn-gold" data-i18n="res.submit">Verstuur aanvraag</button><p class="form-note" data-i18n="res.note2">Uw aanvraag wordt direct naar ons verstuurd — geen e-mailprogramma nodig. Wij bevestigen persoonlijk.</p><div class="form-status" role="status" aria-live="polite"></div></form>
