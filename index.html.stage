<!--MODAL-->
<div class="res-dim" id="resDim" hidden></div>
<div class="res-modal-wrap" id="resModal" role="dialog" aria-modal="true" aria-hidden="true">
  <div class="res-flip" id="resFlip">
    <div class="res-face res-front" id="resFront" aria-hidden="true"></div>
    <div class="res-face res-back">
      <button type="button" class="res-x" id="resX" aria-label="Sluiten" data-i18n-attr="aria-label:res.close">&times;</button>
      <div id="resSlot"></div>
